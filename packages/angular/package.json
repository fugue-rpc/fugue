{
  "name": "@fugue-rpc/angular",
  "version": "0.1.0",
  "type": "module",
  "description": "Angular services for fugue — FugueUnaryService, FugueServerStreamService, FugueBidiStreamService",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fugue-rpc/fugue.git",
    "directory": "packages/angular"
  },
  "keywords": ["grpc", "websocket", "protobuf", "rpc", "browser", "angular", "streaming", "signals"],
  "files": [
    "dist",
    "!dist/**/*.spec.*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm build",
    "test": "vitest run"
  },
  "dependencies": {
    "@fugue-rpc/transport": "workspace:*"
  },
  "peerDependencies": {
    "@angular/core": ">=17.0.0",
    "rxjs": ">=7.4.0"
  },
  "devDependencies": {
    "@angular/core": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "jsdom": "^26.1.0",
    "rxjs": "^7.8.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3",
    "zone.js": "^0.15.0"
  }
}
