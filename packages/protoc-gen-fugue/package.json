{
  "name": "@fugue-rpc/protoc-gen-fugue",
  "version": "0.1.0",
  "type": "module",
  "description": "protoc plugin: generates fugue TypeScript clients from .proto files",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fugue-rpc/fugue.git",
    "directory": "packages/protoc-gen-fugue"
  },
