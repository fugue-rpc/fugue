{
  "name": "@grpcws/react",
  "version": "0.1.0",
  "type": "module",
  "description": "React hooks for grpcws — useUnary, useServerStream, useBidiStream",
  "license": "MIT",
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@grpcws/transport": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
